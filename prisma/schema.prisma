generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  applications  Application[]
  messages      Message[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Application {
  id            String            @id @default(cuid())
  userId        String
  status        ApplicationStatus @default(RECEIVED)

  // Personal info
  fullName      String
  email         String
  phone         String
  dateOfBirth   DateTime
  passportNumber String

  // Address
  address       String
  city          String
  postalCode    String
  country       String

  // Payment
  paymentId     String?
  paymentStatus PaymentStatus     @default(PENDING)
  amount        Float?
  currency      String            @default("EUR")

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User              @relation(fields: [userId], references: [id])
  documents     Document[]
  statusHistory StatusHistory[]
  messages      Message[]
  adminNotes    AdminNote[]
  payment       Payment?
  generatedPdfs GeneratedPDF[]
  lead          Lead?
  signature     ApplicationSignature?
}

model ApplicationSignature {
  id            String      @id @default(cuid())
  applicationId String      @unique
  image         Bytes       // encrypted PNG: iv (12B) || authTag (16B) || ciphertext
  consentText   String
  consentGiven  Boolean
  ipAddress     String
  userAgent     String
  signedAt      DateTime    @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Document {
  id            String       @id @default(cuid())
  applicationId String
  name          String
  type          DocumentType
  url           String
  size          Int
  mimeType      String
  uploadedAt    DateTime     @default(now())

  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  applicationId   String        @unique
  stripeSessionId String        @unique
  stripePaymentId String?
  amount          Int
  currency        String        @default("EUR")
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  application     Application   @relation(fields: [applicationId], references: [id])
}

model StatusHistory {
  id            String            @id @default(cuid())
  applicationId String
  status        ApplicationStatus
  note          String?
  changedBy     String
  createdAt     DateTime          @default(now())

  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Message {
  id            String      @id @default(cuid())
  applicationId String
  userId        String
  content       String
  isFromAdmin   Boolean     @default(false)
  readAt        DateTime?
  createdAt     DateTime    @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])
}

model AdminNote {
  id            String      @id @default(cuid())
  applicationId String
  content       String
  createdBy     String
  createdAt     DateTime    @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

// ── CRM ──────────────────────────────────────────────────────────

model Lead {
  id            String      @id @default(cuid())
  email         String
  name          String?
  phone         String?
  status        LeadStatus  @default(NEW)
  source        String      @default("website")
  score         Int         @default(0)
  applicationId String?     @unique
  reminderAt    DateTime?
  reminderNote  String?
  abandonedAt   DateTime?
  lastEmailStep Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  application   Application? @relation(fields: [applicationId], references: [id])
  activities    LeadActivity[]
  tags          LeadTag[]      @relation("LeadToLeadTag")

  @@index([status])
  @@index([email])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  content   String
  createdBy String?
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadTag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#d4af37")
  createdAt DateTime @default(now())

  leads     Lead[]   @relation("LeadToLeadTag")
}

// ── Team & social proof ──────────────────────────────────────────

model TeamMember {
  id             String   @id @default(cuid())
  name           String
  title          String
  role           TeamRole @default(ADVISOR)
  photoUrl       String?
  bio            String   @db.Text
  certifications String[]
  email          String?
  phone          String?
  order          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id          String    @id @default(cuid())
  authorName  String
  rating      Int
  content     String    @db.Text
  source      String    @default("trustpilot")
  externalId  String?   @unique
  publishedAt DateTime  @default(now())
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

// ── PDF / form automation ────────────────────────────────────────

model FormTemplate {
  id          String         @id @default(cuid())
  name        String
  type        String         @unique
  description String?
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  versions    FormVersion[]
}

model FormVersion {
  id             String       @id @default(cuid())
  templateId     String
  version        String
  fieldMapping   Json
  pdfTemplateUrl String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  template       FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  generatedPdfs  GeneratedPDF[]

  @@unique([templateId, version])
}

model GeneratedPDF {
  id            String        @id @default(cuid())
  applicationId String
  formVersionId String?
  type          PdfType
  url           String
  fileName      String
  size          Int           @default(0)
  sentToNotary  Boolean       @default(false)
  sentToLawyer  Boolean       @default(false)
  generatedAt   DateTime      @default(now())

  application   Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  formVersion   FormVersion?  @relation(fields: [formVersionId], references: [id])
}

// ── Email & audit ────────────────────────────────────────────────

model EmailLog {
  id            String    @id @default(cuid())
  to            String
  subject       String
  template      String
  status        String    @default("sent")
  applicationId String?
  leadId        String?
  error         String?
  sentAt        DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String    @db.Text
  metaTitle   String
  metaDesc    String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category    String?
  tags        String[]
  readTime    Int       @default(5)
  imageUrl    String?
}

enum Role {
  ADMIN
  CUSTOMER
}

enum ApplicationStatus {
  RECEIVED
  PROCESSING
  AT_NOTARY
  AT_LAWYER
  AWAITING_CLIENT
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum DocumentType {
  PASSPORT
  PROOF_OF_ADDRESS
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  PAID
  CONVERTED
  LOST
}

enum TeamRole {
  LAWYER
  NOTARY
  ADVISOR
}

enum PdfType {
  EX18_FORM
  CUSTOMER_RECEIPT
  CASE_OVERVIEW
  NOTARY_PACKAGE
  LAWYER_PACKAGE
}
