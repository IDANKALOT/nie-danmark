# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nie_danmark"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="your-super-secret-key-min-32-chars"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="NIE Danmark <info@nie-danmark.dk>"

# Admin & case-handling contacts
ADMIN_EMAIL="admin@nie-danmark.dk"
NOTARY_EMAIL="notar@nie-danmark.dk"
LAWYER_EMAIL="advokat@nie-danmark.dk"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Vercel Blob (PDF & image storage)
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Vercel Cron (protects /api/cron/* routes — Vercel injects this automatically in production)
CRON_SECRET="your-cron-secret"

# Reviews / social proof
NEXT_PUBLIC_TRUSTPILOT_EMBED="false"
NEXT_PUBLIC_TRUSTPILOT_BUSINESS_UNIT_ID=""
